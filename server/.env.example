# exist server 환경변수
PORT=4000

# AI agent — 설정하면 OpenAI API로 nowbar 브리핑·카드 결정, 없으면 규칙 기반 폴백
# https://platform.openai.com/api-keys 에서 발급
OPENAI_API_KEY=
# 모델 (기본 gpt-4o-mini) — gpt-4o 등으로 바꿀 수 있음
OPENAI_MODEL=gpt-4o-mini

# mediasoup — 배포 시 서버 공인 IP (개발은 비워두면 127.0.0.1)
ANNOUNCED_IP=
RTC_MIN_PORT=40000
RTC_MAX_PORT=40100
